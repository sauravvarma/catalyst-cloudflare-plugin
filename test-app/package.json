{
    "name": "test-app",
    "version": "1.0.0",
    "scripts": {
        "start": "catalyst start",
        "build": "catalyst build",
        "serve": "catalyst serve",
        "lint": "eslint .",
        "devBuild": "catalyst devBuild",
        "devServe": "catalyst devServe",
        "buildApp": "catalyst buildApp",
        "buildApp:ios": "catalyst buildApp:ios",
        "buildApp:android": "catalyst buildApp:android",
        "setupEmulator": "catalyst setupEmulator",
        "setupEmulator:ios": "catalyst setupEmulator:ios",
        "setupEmulator:android": "catalyst setupEmulator:android",
        "build:worker": "node node_modules/catalyst-cloudflare/prebuild.mjs",
        "dev:worker": "npm run build && npm run build:worker && wrangler dev",
        "deploy:worker": "npm run build && npm run build:worker && wrangler deploy"
    },
    "_moduleAliases": {
        "@api": "api.js",
        "@containers": "src/js/containers",
        "@server": "server",
        "@config": "config",
        "@css": "src/static/css",
        "@routes": "src/js/routes/"
    },
    "dependencies": {
        "@loadable/component": "^5.16.3",
        "@tailwindcss/postcss": "^4.1.4",
        "@tata1mg/router": "0.1.0-beta",
        "catalyst-core": "0.2.0-beta.2",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "tailwindcss": "^4.1.4"
    },
    "devDependencies": {
        "catalyst-cloudflare": "file:../adapter",
        "eslint": "^8.26.0",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "wrangler": "^4.110.0"
    },
    "overrides": {
        "react-helmet-async": {
            "react": "^16.6.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
            "react-dom": "^16.6.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
        },
        "@loadable/component": {
            "react": "^16.3.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
            "react-dom": "^16.3.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
        },
        "@loadable/server": {
            "react": "^16.3.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
            "react-dom": "^16.3.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
        }
    },
    "description": "test app for testing cloudflare deployments for catalyst"
}
